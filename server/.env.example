PORT=5000
NODE_ENV=development

# Supabase — copy to .env and fill from Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# JWT — use a long random string in production
JWT_SECRET=

# AI Engine (optional)
AI_ENGINE_URL=http://localhost:8000

# OpenWeatherMap (optional)
OPENWEATHER_API_KEY=
